<!DOCTYPE html>
<html>
{{> fragments/html_header}}
<body>
{{> fragments/nav}}
<h2>Community Forum</h2>
{{> fragments/error_message}}
<h3>New Post</h3>
<form method="post" action="/forum/create">
    <input name="title" type="text" placeholder="Title" style="width:300px"><br>
    <textarea name="body" rows="4" cols="50" placeholder="Body"></textarea><br>
    <button type="submit">Post</button>
</form>
<h3>Posts</h3>
{{#posts}}
<div style="border:1px solid black; margin:5px; padding:5px;">
    <strong>{{title}}</strong> by {{username}} at {{postedAt}}<br>
    {{body}}
</div>
{{/posts}}
{{> fragments/footer}}
</body>
</html>
