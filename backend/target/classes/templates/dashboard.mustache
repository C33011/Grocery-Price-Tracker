<!DOCTYPE html>
<html>
{{> fragments/html_header}}
<body>
{{> fragments/nav}}
<h2>Dashboard</h2>
<p>Welcome, {{loggedInUser.firstName}}!</p>
{{> fragments/error_message}}
<h3>Featured Products</h3>
<table border="1">
    <tr><th>Name</th><th>Category</th><th>Brand</th><th>Size</th><th>Detail</th></tr>
    {{#featuredProducts}}
    <tr>
        <td>{{productName}}</td>
        <td>{{category}}</td>
        <td>{{brand}}</td>
        <td>{{unitSize}} {{unitType}}</td>
        <td><a href="/products/{{productId}}">View</a></td>
    </tr>
    {{/featuredProducts}}
</table>
<h3>Price Alerts</h3>
<p>These products are currently priced below their 12-month average!</p>
<table border="1">
    <tr>
        <th>Product</th>
        <th>Store</th>
        <th>Chain</th>
        <th>Current Price</th>
        <th>Avg Price</th>
        <th>% Below Avg</th>
        <th>Detail</th>
    </tr>
    {{#priceAlerts}}
    <tr>
        <td>{{productName}}</td>
        <td>{{storeName}}</td>
        <td>{{chain}}</td>
        <td>${{currentPrice}}</td>
        <td>${{avgPrice}}</td>
        <td>{{pctBelowAvg}}% off</td>
        <td><a href="/products/{{productId}}">View</a></td>
    </tr>
    {{/priceAlerts}}
</table>
{{> fragments/footer}}
</body>
</html>
